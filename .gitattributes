# Auto detect text files and perform LF normalization
* text=auto

# Force text files to use LF
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.lib text eol=lf
*.cir text eol=lf
*.asc text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
